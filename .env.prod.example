# Copy to /opt/ama-midi/.env.prod on the VPS
# chmod 600 .env.prod

# GHCR image owner (must match GitHub username/org)
GITHUB_OWNER=your_github_username
IMAGE_TAG=latest

# App
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://ama-midi.example.com

# PostgreSQL (external or Docker service name: postgres)
DATABASE_URL=postgresql://app_user:change_me@your-db-host:5432/ama_midi?schema=public

# Redis (Docker service name: redis)
REDIS_URL=redis://redis:6379

# Auth — JWT must be at least 32 characters
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars

# Google OAuth — must match Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://ama-midi.example.com/auth/google/callback

# AI (optional — Suggest feature disabled if empty)
ANTHROPIC_API_KEY=
